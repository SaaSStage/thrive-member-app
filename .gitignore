# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env
.env.*
env.local
!.env.example

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# Local Claude Code permission overrides (machine-specific)
.claude/settings.local.json

