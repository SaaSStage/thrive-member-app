# THRIVE Member App — environment template
# Copy to `.env` and fill with the v3 project values. `.env` is gitignored.
#
# NEVER put the PRODUCTION Supabase keys here.
#   Production (live Flutter app) = mxktlbhiknpdauzoitnm — DO NOT USE.
#   This rebuild uses the v3 project = yotaqkgfpifomudtwgzr.

# Supabase (v3 project)
EXPO_PUBLIC_SUPABASE_URL=https://yotaqkgfpifomudtwgzr.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Clerk (publishable key is client-safe; secret key never goes in the app)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# AzuraCast (streaming + now-playing API base)
EXPO_PUBLIC_AZURACAST_BASE_URL=

# WHOOP OAuth (public client_id only — the client secret lives exclusively in the backend edge functions)
EXPO_PUBLIC_WHOOP_CLIENT_ID=
